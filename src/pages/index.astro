---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { ICON_MAP } from '../utils/icons';

const posts = (await getCollection('posts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base title="From the Forge — Pyris">
  <!-- Forge watermark slot: fixed behind card grid, z-index 0 -->
  <div class="blog-watermark" slot="watermark" aria-hidden="true">
    <img src="/assets/from-the-forge-logo.png" alt="" />
  </div>

  <section class="blog-index__section">
    <div class="blog-index__inner">
      <h1 class="blog-index__heading reveal">FROM THE FORGE</h1>
      <p class="blog-index__sub reveal">Pyris · Practitioner guides on operations, AI, and systems that don't drift.</p>

      <div class="post-grid">
        {posts.map(post => {
          const iconSvg = ICON_MAP[post.data.icon] ?? ICON_MAP['inventory'];
          return (
            <a href={`/${post.data.slug}/`} class="post-card pop-reveal">
              <div class="post-card__meta">
                <span class="post-card__date">{post.data.date}</span>
                <span class="post-card__icon" aria-hidden="true" set:html={iconSvg}></span>
              </div>
              <div class="post-card__title">{post.data.title}</div>
              <p class="post-card__desc">{post.data.description}</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Base>
