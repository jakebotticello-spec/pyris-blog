---
import Base from './Base.astro';
import { ICON_MAP } from '../utils/icons';

interface Props {
  title: string;
  description: string;
  date: string;
  icon: string;
}

const { title, description, date, icon } = Astro.props;
const iconSvg = ICON_MAP[icon] ?? ICON_MAP['inventory'];
---

<Base title={`${title} — From the Forge`} description={description} showForgeLink={true}>
  <div class="article-frame">
    <div class="blog-meta__row">
      <span class="blog-meta__date">{date} • Jake Botticello</span>
      <span class="blog-meta__icon" aria-hidden="true" set:html={iconSvg}></span>
    </div>
    <h1>{title}</h1>
    <p class="article-description">{description}</p>
    <hr />
    <slot />
  </div>
</Base>
